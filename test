#!/bin/bash

### Go to Directory
cd ~/Desktop/Research/Projects/"2. DCI-Project"/Code || exit

### ONE-TIME: Rewrite all commit timestamps to UTC
### (Only run this once — comment out or remove after use)
rewriteUTC=false
if [ "$rewriteUTC" = true ]; then
    echo "Rewriting all commit dates to UTC (+0000)..."
    git filter-repo --force --commit-callback '
commit.author_date = commit.author_date.split(b" ")[0] + b" +0000"
commit.committer_date = commit.committer_date.split(b" ")[0] + b" +0000"
'
    echo "Rewrite complete. You will need to re-add your remote and force-push."
    exit 0
fi

### Add updates
git add .
git status

### Ask user if they want to continue
echo "Do you want to continue with commit? (y/n)"
read -r confirm

if [ "$confirm" != "y" ]; then
    echo "Exiting without commit."
    exit 0
fi

### Enter Commit Message
echo "Enter your commit message:"
read -r commitMessage
git commit -m "$commitMessage"

git pull --rebase origin main
git push origin main
